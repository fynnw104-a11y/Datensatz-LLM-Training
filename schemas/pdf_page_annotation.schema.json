{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trading PDF Page Annotation",
  "type": "object",
  "required": [
    "id",
    "image_path",
    "json_path",
    "source_pdf",
    "page_number",
    "page_type",
    "combined_text",
    "target_json",
    "review_required"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "annotation_version": {
      "type": "string"
    },
    "image_path": {
      "type": "string",
      "minLength": 1
    },
    "json_path": {
      "type": "string",
      "minLength": 1
    },
    "source_pdf": {
      "type": "string",
      "minLength": 1
    },
    "page_number": {
      "type": "integer",
      "minimum": 1
    },
    "page_type": {
      "type": "string",
      "enum": [
        "chart",
        "trade_journal",
        "performance_report",
        "strategy_note",
        "market_analysis",
        "educational_note",
        "unknown"
      ]
    },
    "page_type_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "summary": {
      "type": "string"
    },
    "embedded_text": {
      "type": "string"
    },
    "ocr_text": {
      "type": "string"
    },
    "combined_text": {
      "type": "string"
    },
    "extraction_methods": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ocr_metadata": {
      "type": "object"
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timeframes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trading_concepts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trading_domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "labels": {
      "type": "object"
    },
    "review_required": {
      "type": "boolean"
    },
    "asset_count": {
      "type": "integer",
      "minimum": 0
    },
    "asset_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target_json": {
      "type": "object",
      "required": [
        "page_type",
        "summary",
        "clean_text",
        "symbols",
        "timeframes",
        "trading_concepts",
        "trading_domains",
        "labels"
      ],
      "properties": {
        "page_type": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "clean_text": {
          "type": "string"
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeframes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trading_concepts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trading_domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "labels": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
