{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compact Multimodal Training Pair",
  "type": "object",
  "required": [
    "schema_version",
    "task_type",
    "response"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1"
    },
    "task_type": {
      "type": "string",
      "const": "strict_image_to_json"
    },
    "response": {
      "type": "object",
      "properties": {
        "asset_type": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "primary_symbol": {
          "type": "string"
        },
        "instrument_name": {
          "type": "string"
        },
        "venue": {
          "type": "string"
        },
        "timeframes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instrument": {
          "type": "object",
          "properties": {
            "primary_symbol": {
              "type": "string"
            },
            "instrument_name": {
              "type": "string"
            },
            "venue": {
              "type": "string"
            },
            "timeframes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "visible_text": {
          "type": "string"
        },
        "visible_text_details": {
          "type": "object",
          "properties": {
            "main_header": {
              "type": "string"
            },
            "indicator_text": {
              "type": "string"
            },
            "watermark": {
              "type": "string"
            },
            "other_text_readability": {
              "type": "string"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "short_caption": {
          "type": "string"
        },
        "visual_summary": {
          "type": "string"
        },
        "chart_content": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "boolean"
            ]
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "key_visual_elements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
