{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trading LLM Training Example",
  "type": "object",
  "required": ["id", "messages", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "messages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": ["task_type", "source_path"],
      "properties": {
        "task_type": {
          "type": "string",
          "enum": ["knowledge", "decision", "review", "normalization"]
        },
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "symbol": {
          "type": ["string", "null"]
        },
        "timeframe": {
          "type": ["string", "null"]
        },
        "reviewed": {
          "type": ["boolean", "null"]
        },
        "split_hint": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

